####################################################
# CI4 DOCKER PREMIUM - ENV TEMPLATE
####################################################

############################
# APP
############################

CI_ENVIRONMENT=development
app.baseURL=http://localhost:8080
app.forceGlobalSecureRequests=false
app.CSPEnabled=false
app.logPath=writable/logs

############################
# DATABASE
############################

database.default.hostname=mysql
database.default.database=ci4
database.default.username=ci4
database.default.password=ci4
database.default.DBDriver=MySQLi
database.default.port=3306
database.default.DBDebug=true

############################
# REDIS
############################

cache.handler=redis
cache.prefix=ci4_
cache.redis.host=redis
cache.redis.port=6379
cache.redis.password = 
cache.redis.database = 0
cache.redis.timeout = 2.0

############################
# SESSION
############################

session.driver=CodeIgniter\Session\Handlers\FileHandler

############################
# QUEUES (Daycry)
############################

queue.default = redis
queue.connection.redis.host = redis
queue.connection.redis.port = 6379

############################
# SECURITY
############################

security.csrfProtection=cookie
security.tokenRandomize=true
security.headerName=X-CSRF-TOKEN
security.cookieName=csrf_cookie

############################
# LOGGING
############################

logger.threshold=4

############################
# OBSERVABILITY (SENTRY)
############################

sentry.dsn=
sentry.environment=development
sentry.traces_sample_rate=1.0

############################
# EMAIL (OPTIONAL)
############################

email.protocol=smtp
email.SMTPHost=
email.SMTPUser=
email.SMTPPass=
email.SMTPPort=587

############################
# FEATURE FLAGS
############################

feature.cache_enabled=true
feature.queue_enabled=true
feature.sentry_enabled=false
feature.healthcheck_enabled=true
feature.debug_mode=true
feature.rate_limit_enabled=false
feature.maintenance_mode=false