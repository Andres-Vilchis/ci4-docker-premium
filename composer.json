{
    "name": "ci4-docker/premium-starter-kit",
    "description": "Production-ready CodeIgniter 4 Docker Starter Kit with CI/CD, Redis, Queues, Observability",
    "license": "MIT",
    "type": "project",

    "require": {
        "php": "^8.2",
        "codeigniter4/framework": "^4.7",
        "codeigniter4/shield": "^1.3"
    },

    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5.16",
        "phpstan/phpstan": "^1.11",
        "rector/rector": "^1.0"
    },

    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },

    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },

    "scripts": {
        "test": "phpunit",
        "test:ci": "phpunit --colors=always",
        "stan": "phpstan analyse",
        "rector": "rector process",
        "rector:dry": "rector process --dry-run",

        "check": [
            "@stan",
            "@rector:dry",
            "@test"
        ]
    }
}
